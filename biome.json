{
    "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
    "files": {},
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "enabled": true,
        "includes": ["./assets/**/*.js", "./assets/**/*.html"]
    },
    "linter": {
        "enabled": true,
        "includes": ["./assets/**/*.js", "./assets/**/*.html"],
        "rules": {}
    },
    "assist": {
        "enabled": false
    },
    "javascript": {
        "formatter": {
            "trailingCommas": "all"
        }
    },
    "html": {
        "formatter": {
            "indentWidth": 2
        }
    }
}
